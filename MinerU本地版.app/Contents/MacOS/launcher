#!/bin/bash
# MinerU 本地版 — 无页数限制的 Web UI

export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$PATH"
export HF_HUB_OFFLINE=1
export MINERU_MODEL_SOURCE=modelscope

MINERU_VENV="/Users/Apple/MinerU-src/.venv"
MINERU_PYTHON="$MINERU_VENV/bin/python3"
MINERU_SRC="/Users/Apple/MinerU-src"
PORT=7860

# 检查端口是否被占用
if lsof -Pi ":$PORT" -sTCP:LISTEN -t >/dev/null 2>&1; then
    PORT=$((PORT + RANDOM % 100 + 1))
fi

/usr/bin/osascript -e "display notification \"正在启动 MinerU 本地版（端口 $PORT）...\" with title \"MinerU 本地版\""

cd "$MINERU_SRC"
"$MINERU_PYTHON" -m mineru.cli.gradio_app --port "$PORT" &

# 等待服务启动
for i in $(seq 1 30); do
    if curl -s -o /dev/null http://127.0.0.1:$PORT 2>/dev/null; then
        /usr/bin/osascript -e "display notification \"已启动，正在打开浏览器...\" with title \"MinerU 本地版\""
        open "http://127.0.0.1:$PORT"
        wait
        exit 0
    fi
    sleep 1
done

/usr/bin/osascript -e "display alert \"启动超时\" message \"MinerU 本地版未能在 30 秒内启动。\"" 2>/dev/null || true
exit 1
